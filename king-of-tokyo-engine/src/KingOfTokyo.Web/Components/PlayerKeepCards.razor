@using WebCardDto = KingOfTokyo.Web.Contracts.CardDto

<div class="owned-card-list">
    <small class="owned-card-heading">Keep cards</small>
    @if (Cards.Count == 0)
    {
        <small class="muted">No keep cards</small>
    }
    else
    {
        <div class="owned-card-row">
            @foreach (var card in Cards)
            {
                <div class="owned-card-chip card-art-surface" aria-label="@($"Keep card {card.Name}. {card.Description}")">
                    <button class="card-art-frame compact-card-art keep-card-art" type="button" data-card-id="@card.CardId" data-card-name="@card.Name" aria-label="@($"Show {card.Name} card detail")">
                        <img src="@CardImagePath(card)" alt="@card.Name card art" loading="lazy" onerror="this.closest('.card-art-surface')?.classList.add('missing-card-art'); this.remove();" />
                        <div class="card-art-fallback">
                            <strong>@card.Name</strong>
                            <small>@card.CardType • Cost @card.Cost</small>
                        </div>
                    </button>
                    @if (card.Counters > 0 || card.StoredEnergy > 0 || card.MimicTarget is not null)
                    {
                        <div class="owned-card-meta compact-owned-card-meta">
                            @if (card.Counters > 0)
                            {
                                <span>@card.Counters counters</span>
                            }
                            @if (card.StoredEnergy > 0)
                            {
                                <span>@card.StoredEnergy energy</span>
                            }
                            @if (card.MimicTarget is not null)
                            {
                                <span>Mimic: @card.MimicTarget.CardName</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<WebCardDto> Cards { get; set; } = Array.Empty<WebCardDto>();

    private static string CardImagePath(WebCardDto card) => $"images/cards/{card.CardId}.jpg";
}
