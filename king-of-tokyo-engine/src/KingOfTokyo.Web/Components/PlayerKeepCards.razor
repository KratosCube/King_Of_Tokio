@using WebCardDto = KingOfTokyo.Web.Contracts.CardDto

<div class="owned-card-list">
    <small class="owned-card-heading">Keep cards</small>
    @if (Cards.Count == 0)
    {
        <small class="muted">No keep cards</small>
    }
    else
    {
        <div class="owned-card-row">
            @foreach (var card in Cards)
            {
                var isActionable = IsActionAvailable?.Invoke(card) == true;
                var isSelected = IsSelected?.Invoke(card) == true;
                <div class="owned-card-chip card-art-surface @(isActionable ? "actionable-keep-card" : null) @(isSelected ? "selected-keep-card" : null)" aria-label="@($"Keep card {card.Name}. {card.Description}")">
                    <button class="card-art-frame compact-card-art keep-card-art" type="button" data-card-id="@card.CardId" data-card-name="@card.Name" aria-label="@($"Show {card.Name} card detail")" @onclick="() => HandleCardClickedAsync(card)">
                        <img src="@CardImagePath(card)" alt="@card.Name card art" loading="lazy" onerror="this.closest('.card-art-surface')?.classList.add('missing-card-art'); this.remove();" />
                        <div class="card-art-fallback">
                            <strong>@card.Name</strong>
                            <small>@card.CardType • Cost @card.Cost</small>
                        </div>
                    </button>
                    @if (card.Counters > 0 || card.StoredEnergy > 0 || card.MimicTarget is not null || isActionable)
                    {
                        <div class="owned-card-meta compact-owned-card-meta">
                            @if (card.Counters > 0)
                            {
                                <span>@card.Counters counters</span>
                            }
                            @if (card.StoredEnergy > 0)
                            {
                                <span>@card.StoredEnergy energy</span>
                            }
                            @if (card.MimicTarget is not null)
                            {
                                <span>Mimic: @card.MimicTarget.CardName</span>
                            }
                            @if (isActionable)
                            {
                                <span>@(isSelected ? "Selected" : "Action")</span>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int OwnerPlayerId { get; set; }
    [Parameter] public IReadOnlyList<WebCardDto> Cards { get; set; } = Array.Empty<WebCardDto>();
    [Parameter] public EventCallback<KeepCardClickArgs> OnCardClicked { get; set; }
    [Parameter] public Func<WebCardDto, bool>? IsActionAvailable { get; set; }
    [Parameter] public Func<WebCardDto, bool>? IsSelected { get; set; }

    private async Task HandleCardClickedAsync(WebCardDto card)
    {
        if (OnCardClicked.HasDelegate)
        {
            await OnCardClicked.InvokeAsync(new KeepCardClickArgs(OwnerPlayerId, card));
        }
    }

    private static string CardImagePath(WebCardDto card) => $"/images/cards/{card.CardId}.jpg";

    public sealed record KeepCardClickArgs(int OwnerPlayerId, WebCardDto Card);
}