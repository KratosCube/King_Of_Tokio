@page "/"

<section class="hero">
    <div class="card">
        <p class="status-pill">First playable web prototype</p>
        <h1>Become the King of Tokyo</h1>
        <p class="muted">
            Create a lobby, invite another monster, and start a headless-engine powered online match.
            This UI is intentionally simple first: validate the full flow, then polish.
        </p>
        <div class="actions">
            <NavLink class="btn btn-primary" href="lobbies/new">Create lobby</NavLink>
        </div>
    </div>

    <div class="panel">
        <h2>Prototype scope</h2>
        <ul class="muted">
            <li>Lobby creation and join flow</li>
            <li>Ready and host start</li>
            <li>Snapshot-driven game table</li>
            <li>Basic turn command buttons</li>
            <li>Event cursor integration next</li>
        </ul>
    </div>
</section>
