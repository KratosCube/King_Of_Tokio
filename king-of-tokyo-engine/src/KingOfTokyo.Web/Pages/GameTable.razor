@page "/games/{GameId:guid}"
@implements IDisposable
@inject ApiClient ApiClient
@inject ClientSessionState Session

<div class="card">
    <h1>Game table</h1>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="status-pill">@_error</p>
    }

    @if (_game is null)
    {
        <p class="muted">Loading game...</p>
    }
    else
    {
        <p>
            Status: <span class="status-pill">@_game.Status</span>
            Version: <span class="muted">@_game.Version</span>
        </p>

        @if (_game.WinnerPlayerId is not null)
        {
            <p class="status-pill">Winner: @PlayerName(_game.WinnerPlayerId.Value) — @_game.WinnerReason</p>
        }

        <div class="game-grid">
            <section class="panel">
                <h2>Monsters</h2>
                <div class="monster-grid stacked-monsters">
                    @foreach (var player in _game.Players)
                    {
                        var monster = MonsterCatalog.FindByName(player.MonsterName);
                        <article class="monster-card display-card @(player.PlayerId == Session.PlayerId ? "selected" : null)" style="--accent:@monster.Accent">
                            <span class="monster-emoji">@monster.Emoji</span>
                            <strong>@player.MonsterName</strong>
                            <small>Player #@player.PlayerId • @player.TokyoSlot</small>
                            <div class="monster-stats">
                                <span>HP @player.Health/@player.MaxHealth</span>
                                <span>VP @player.VictoryPoints</span>
                                <span>⚡ @player.Energy</span>
                            </div>
                            @if (!player.IsAlive)
                            {
                                <span class="status-pill danger-pill">Eliminated</span>
                            }
                        </article>
                    }
                </div>
            </section>

            <section class="panel">
                <h2>Tokyo</h2>
                <div class="tokyo-board">
                    @RenderTokyoSlot("Tokyo City", _game.Tokyo.CityOccupantId, isEnabled: true)
                    @RenderTokyoSlot("Tokyo Bay", _game.Tokyo.BayOccupantId, _game.Tokyo.BayEnabled)
                </div>

                <h2>Dice</h2>
                @if (_game.CurrentTurn?.Dice.Count > 0)
                {
                    <div class="dice-row">
                        @foreach (var die in _game.CurrentTurn.Dice)
                        {
                            <span class="die-face @(die.IsLocked ? "locked" : null)">@DieIcon(die.CurrentFace)</span>
                        }
                    </div>
                }
                else
                {
                    <div class="placeholder-box">Dice will appear here after rolling.</div>
                }
            </section>

            <section class="panel">
                <h2>Market</h2>
                @foreach (var card in _game.Market.FaceUpCards.Select((value, index) => new { value, index }))
                {
                    <div class="panel">
                        @if (card.value is null)
                        {
                            <p class="muted">Slot @card.index: empty</p>
                        }
                        else
                        {
                            <h3>@card.value.Name</h3>
                            <p class="muted">Cost: @card.value.Cost • @card.value.CardType</p>
                            <p>@card.value.Description</p>
                        }
                    </div>
                }
                <p class="muted">Deck: @_game.Market.DrawPileCount • Discard: @_game.Market.DiscardPileCount</p>
            </section>
        </div>

        <section class="panel">
            <h2>Commands</h2>
            <p class="muted">Current local player id: @(Session.PlayerId?.ToString() ?? "unknown")</p>
            <div class="actions">
                <button class="btn btn-secondary" @onclick="InitializeAsync" disabled="@_busy">Initialize</button>
                <button class="btn btn-secondary" @onclick="BeginTurnAsync" disabled="@_busy">Begin turn</button>
                <button class="btn btn-primary" @onclick="RollDiceAsync" disabled="@_busy">Roll dice</button>
                <button class="btn btn-primary" @onclick="FinalizeDiceAsync" disabled="@_busy">Finalize dice</button>
                <button class="btn btn-secondary" @onclick="EndTurnAsync" disabled="@_busy">End turn</button>
                <button class="btn btn-secondary" @onclick="AdvancePlayerAsync" disabled="@_busy">Advance player</button>
                <button class="btn btn-secondary" @onclick="RefreshAsync" disabled="@_busy">Refresh</button>
            </div>
        </section>
    }
</div>

@code {
    [Parameter] public Guid GameId { get; set; }

    private GameStateDto? _game;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;
    private bool _busy;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        Session.RememberGame(GameId);
        await RefreshAsync();
        _cts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = PollAsync(_cts.Token);
    }

    private RenderFragment RenderTokyoSlot(string title, int? playerId, bool isEnabled) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", $"tokyo-slot {(isEnabled ? string.Empty : "disabled-slot")}");
        builder.OpenElement(sequence++, "h3");
        builder.AddContent(sequence++, title);
        builder.CloseElement();

        if (!isEnabled)
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "muted");
            builder.AddContent(sequence++, "Disabled for this player count");
            builder.CloseElement();
        }
        else if (playerId is null || _game is null)
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "muted");
            builder.AddContent(sequence++, "Empty");
            builder.CloseElement();
        }
        else
        {
            var player = _game.Players.FirstOrDefault(p => p.PlayerId == playerId.Value);
            var monster = MonsterCatalog.FindByName(player?.MonsterName);
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "tokyo-occupant");
            builder.AddAttribute(sequence++, "style", $"--accent:{monster.Accent}");
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "monster-emoji");
            builder.AddContent(sequence++, monster.Emoji);
            builder.CloseElement();
            builder.OpenElement(sequence++, "strong");
            builder.AddContent(sequence++, player?.MonsterName ?? $"Player {playerId}");
            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private string PlayerName(int playerId)
    {
        return _game?.Players.FirstOrDefault(player => player.PlayerId == playerId)?.MonsterName ?? $"Player {playerId}";
    }

    private static string DieIcon(string face)
    {
        return face switch
        {
            "One" => "1",
            "Two" => "2",
            "Three" => "3",
            "Energy" => "⚡",
            "Heal" => "❤",
            "Attack" => "🗯",
            _ => face
        };
    }

    private async Task PollAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (_timer is not null && await _timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(RefreshAsync);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task RefreshAsync()
    {
        try
        {
            _game = await ApiClient.GetGameAsync(GameId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ExecuteAsync(Func<Task<ApiCommandResultDto>> command)
    {
        _busy = true;
        _error = null;

        try
        {
            var result = await command();
            if (!result.Success)
            {
                _error = result.Error;
            }

            _game = result.GameState;
            Session.LastEventSequence = result.CurrentEventSequence;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private Task InitializeAsync() => ExecuteAsync(() => ApiClient.InitializeGameAsync(GameId));

    private Task BeginTurnAsync() => ExecuteAsync(() => ApiClient.BeginTurnAsync(GameId, new ActorRequest(Session.PlayerId)));

    private Task RollDiceAsync() => ExecuteAsync(() => ApiClient.RollDiceAsync(GameId, new ActorRequest(Session.PlayerId)));

    private Task FinalizeDiceAsync() => ExecuteAsync(() => ApiClient.FinalizeDiceAsync(GameId, new ActorRequest(Session.PlayerId)));

    private Task EndTurnAsync() => ExecuteAsync(() => ApiClient.EndTurnAsync(GameId, new ActorRequest(Session.PlayerId)));

    private Task AdvancePlayerAsync() => ExecuteAsync(() => ApiClient.AdvancePlayerAsync(GameId, new ActorRequest(Session.PlayerId)));

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _timer?.Dispose();
    }
}
