    private Task ChooseLeaveTokyoAsync(bool leaveTokyo)
    {
        if (_game?.PendingDecision is null)
        {
            return Task.CompletedTask;
        }

        return ExecuteAsync(() => ApiClient.ChooseLeaveTokyoAsync(GameId, new ChooseLeaveTokyoRequest(_game.PendingDecision.PlayerId, leaveTokyo)));
