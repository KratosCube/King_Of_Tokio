@page "/games/{GameId:guid}"
@implements IDisposable
@inject ApiClient ApiClient
@inject ClientSessionState Session

<div class="card game-hero">
    <p class="status-pill">Tokyo battle arena</p>
    <h1>Tokyo arena</h1>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="status-pill danger-pill">@_error</p>
    }

    @if (_game is null)
    {
        <p class="muted">Loading game...</p>
    }
    else
    {
        <div class="game-status-strip">
            <section class="status-card primary-status">
                <span>Next action</span>
                <strong>@SmartActionTitle</strong>
                <small>@SmartActionDescription</small>
            </section>
            <section class="status-card">
                <span>You control</span>
                <strong>@LocalPlayerLabel</strong>
                <small>Local player id: @(Session.PlayerId?.ToString() ?? "unknown")</small>
            </section>
            <section class="status-card @(IsLocalActor ? "your-turn-card" : null)">
                <span>Active monster</span>
                <strong>@ActiveTurnLabel</strong>
                <small>@ActorPillText</small>
            </section>
            <section class="status-card">
                <span>State</span>
                <strong>@_game.Status</strong>
                <small>Phase: @PhaseLabel • Rolls: @RollsLabel • Events: @Session.LastEventSequence</small>
            </section>
        </div>

        @if (_game.WinnerPlayerId is not null)
        {
            <p class="status-pill">Winner: @PlayerName(_game.WinnerPlayerId.Value) — @_game.WinnerReason</p>
        }

        <div class="game-grid">
            <section class="panel">
                <h2>Monsters</h2>
                <div class="monster-grid stacked-monsters">
                    @foreach (var player in _game.Players)
                    {
                        var monster = MonsterCatalog.FindByName(player.MonsterName);
                        <article class="@MonsterCardClass(player)" style="--accent:@monster.Accent">
                            <span class="monster-emoji">@monster.Emoji</span>
                            <strong>@player.MonsterName</strong>
                            <small>Player #@player.PlayerId • @player.TokyoSlot</small>
                            <div class="monster-badge-row">
                                @if (player.PlayerId == Session.PlayerId)
                                {
                                    <span class="status-pill">You control</span>
                                }
                                @if (player.PlayerId == CurrentActorId)
                                {
                                    <span class="status-pill turn-pill">Active turn</span>
                                }
                                @if (IsTokyoOccupant(player))
                                {
                                    <span class="status-pill tokyo-pill">In Tokyo</span>
                                }
                                @if (!player.IsAlive)
                                {
                                    <span class="status-pill danger-pill">Eliminated</span>
                                }
                            </div>
                            <div class="monster-stats">
                                <span>HP @player.Health/@player.MaxHealth</span>
                                <span>VP @player.VictoryPoints</span>
                                <span>⚡ @player.Energy</span>
                            </div>
                            <PlayerStatusTokens Status="player.Status" />
                            <PlayerKeepCards Cards="player.KeepCards" />
                        </article>
                    }
                </div>
            </section>

            <section class="panel">
                <h2>Tokyo</h2>
                <div class="tokyo-board">
                    @RenderTokyoSlot("Tokyo City", _game.Tokyo.CityOccupantId, true)
                    @RenderTokyoSlot("Tokyo Bay", _game.Tokyo.BayOccupantId, _game.Tokyo.BayEnabled)
                </div>

                @if (_game.PendingDecision is not null)
                {
                    <section class="decision-panel">
                        <h2>Pending decision</h2>
                        <p><strong>@_game.PendingDecision.DecisionType</strong> <span class="muted">for @PlayerName(_game.PendingDecision.PlayerId)</span></p>
                        @if (CanAnswerLeaveTokyoDecision)
                        {
                            <p class="muted">Tokyo is under attack. Choose whether your monster retreats after taking damage.</p>
                            <div class="actions">
                                <button class="btn btn-primary" @onclick="() => ChooseLeaveTokyoAsync(true)" disabled="@_busy">Leave Tokyo</button>
                                <button class="btn btn-secondary" @onclick="() => ChooseLeaveTokyoAsync(false)" disabled="@_busy">Stay in Tokyo</button>
                            </div>
                        }
                        else if (IsSelectDiceToRerollDecision)
                        {
                            <p class="muted">Select dice below and press Reroll selected dice, or finalize dice to keep the current result.</p>
                        }
                        else
                        {
                            <p class="muted">Waiting for @PlayerName(_game.PendingDecision.PlayerId) to answer this decision.</p>
                        }
                    </section>
                }

                <h2>Dice</h2>
                @if (_game.CurrentTurn?.Dice.Count > 0)
                {
                    <div class="dice-row">
                        @foreach (var die in _game.CurrentTurn.Dice)
                        {
                            var isSelected = _selectedDiceIndexes.Contains(die.Index);
                            <button type="button" class="die-button @(isSelected ? "selected" : null)" disabled="@(_busy || die.IsLocked || !CanSelectDiceForReroll)" @onclick="() => ToggleDieSelection(die.Index)">
                                <span class="die-face @(die.IsLocked ? "locked" : null)">@DieIcon(die.CurrentFace)</span>
                                <small>@(die.IsLocked ? "locked" : isSelected ? "reroll" : $"die {die.Index}")</small>
                            </button>
                        }
                    </div>
                    <div class="actions compact-actions">
                        <button class="btn btn-primary" @onclick="RerollSelectedDiceAsync" disabled="@(!CanRerollSelected || _busy)">Reroll selected dice</button>
                        <button class="btn btn-secondary" @onclick="ClearSelectedDice" disabled="@(_busy || _selectedDiceIndexes.Count == 0)">Clear dice selection</button>
                    </div>
                    @if (_selectedDiceIndexes.Count > 0 && !CanRerollSelected)
                    {
                        <p class="muted">Dice are selected. Reroll becomes available only during your reroll decision.</p>
                    }
                }
                else
                {
                    <div class="placeholder-box">Dice will appear here after rolling.</div>
                }
            </section>

            <section class="panel market-panel">
                <h2>Market</h2>
                <div class="market-list">
                    @foreach (var card in _game.Market.FaceUpCards.Select((value, index) => new { value, index }))
                    {
                        <article class="market-card">
                            @if (card.value is null)
                            {
                                <p class="muted">Slot @card.index: empty</p>
                            }
                            else
                            {
                                <div class="market-card-header">
                                    <h3>@card.value.Name</h3>
                                    <span class="market-cost">⚡ @card.value.Cost</span>
                                </div>
                                <small class="market-card-type">@card.value.CardType</small>
                                <p>@card.value.Description</p>
                                <button class="btn btn-primary" @onclick="() => BuyFaceUpCardAsync(card.index)" disabled="@(_busy || !CanUseMarketActions)">Buy</button>
                            }
                        </article>
                    }
                </div>
                <div class="market-footer">
                    <p class="muted">Deck: @_game.Market.DrawPileCount • Discard: @_game.Market.DiscardPileCount</p>
                    <button class="btn btn-secondary" @onclick="RefreshMarketAsync" disabled="@(_busy || !CanUseMarketActions)">Refresh market</button>
                </div>
            </section>
        </div>

        <div class="grid-2 lower-game-grid">
            <section class="panel next-action-panel">
                <h2>Next action</h2>
                <p class="status-pill">@SmartActionTitle</p>
                <p class="muted">@SmartActionDescription</p>
                <div class="actions">
                    @if (CanInitialize)
                    {
                        <button class="btn btn-primary" @onclick="InitializeAsync" disabled="@_busy">Initialize game</button>
                    }
                    else if (CanBeginTurn)
                    {
                        <button class="btn btn-primary" @onclick="BeginTurnAsync" disabled="@_busy">Begin turn</button>
                    }
                    else if (CanRollDice)
                    {
                        <button class="btn btn-primary" @onclick="RollDiceAsync" disabled="@_busy">Roll dice</button>
                    }
                    else if (CanRerollSelected)
                    {
                        <button class="btn btn-primary" @onclick="RerollSelectedDiceAsync" disabled="@_busy">Reroll selected dice</button>
                        <button class="btn btn-secondary" @onclick="FinalizeDiceAsync" disabled="@_busy">Finalize instead</button>
                    }
                    else if (CanSelectDiceForReroll)
                    {
                        <button class="btn btn-secondary" disabled>Select dice to reroll</button>
                        <button class="btn btn-primary" @onclick="FinalizeDiceAsync" disabled="@_busy">Finalize dice</button>
                    }
                    else if (CanFinalizeDice)
                    {
                        <button class="btn btn-primary" @onclick="FinalizeDiceAsync" disabled="@_busy">Finalize dice</button>
                    }
                    else if (CanUseMarketActions)
                    {
                        <button class="btn btn-primary" @onclick="EndTurnAndAdvanceAsync" disabled="@_busy">End turn & advance</button>
                        <button class="btn btn-secondary" @onclick="EndTurnAsync" disabled="@_busy">End turn only</button>
                        <button class="btn btn-secondary" @onclick="RefreshMarketAsync" disabled="@_busy">Refresh market</button>
                    }
                    else if (CanAdvancePlayer)
                    {
                        <button class="btn btn-primary" @onclick="AdvancePlayerAsync" disabled="@_busy">Advance player</button>
                    }
                    else if (CurrentActorId is not null && !IsLocalActor)
                    {
                        <button class="btn btn-primary" @onclick="() => ControlPlayerAsync(CurrentActorId.Value)" disabled="@_busy">Control active monster</button>
                        <button class="btn btn-secondary" @onclick="RefreshAsync" disabled="@_busy">Refresh</button>
                    }
                    else
                    {
                        <button class="btn btn-secondary" @onclick="RefreshAsync" disabled="@_busy">Refresh</button>
                    }
                </div>
            </section>

            <section class="panel developer-panel">
                <details>
                    <summary class="dev-tools-summary">
                        <span>Debug commands</span>
                        <small>Optional tools while the UI is still being stabilized</small>
                    </summary>
                    <p class="muted">Current local player id: @(Session.PlayerId?.ToString() ?? "unknown")</p>
                    @if (!IsLocalActor && CurrentActorId is not null)
                    {
                        <p class="status-pill">Waiting for @PlayerName(CurrentActorId.Value)</p>
                    }
                    <div class="actions compact-actions">
                        @foreach (var player in _game.Players)
                        {
                            <button class="btn btn-secondary" @onclick="() => ControlPlayerAsync(player.PlayerId)" disabled="@(_busy || Session.PlayerId == player.PlayerId)">Control @player.MonsterName</button>
                        }
                    </div>
                    <div class="actions">
                        <button class="btn btn-secondary" @onclick="InitializeAsync" disabled="@(_busy || !CanInitialize)">Initialize</button>
                        <button class="btn btn-secondary" @onclick="BeginTurnAsync" disabled="@(_busy || !CanBeginTurn)">Begin turn</button>
                        <button class="btn btn-primary" @onclick="RollDiceAsync" disabled="@(_busy || !CanRollDice)">Roll dice</button>
                        <button class="btn btn-primary" @onclick="FinalizeDiceAsync" disabled="@(_busy || !CanFinalizeDice)">Finalize dice</button>
                        <button class="btn btn-secondary" @onclick="EndTurnAsync" disabled="@(_busy || !CanEndTurn)">End turn</button>
                        <button class="btn btn-secondary" @onclick="AdvancePlayerAsync" disabled="@(_busy || !CanAdvancePlayer)">Advance player</button>
                        <button class="btn btn-secondary" @onclick="RefreshAsync" disabled="@_busy">Refresh</button>
                    </div>
                </details>
            </section>

            <section class="panel event-feed-panel">
                <h2>Event feed</h2>
                @if (_eventFeed.Count == 0)
                {
                    <p class="muted">No events yet. Start a turn, roll dice, or buy cards to see the story here.</p>
                }
                else
                {
                    <ol class="event-feed">
                        @foreach (var item in _eventFeed.OrderByDescending(item => item.Sequence).Take(20))
                        {
                            <li><span class="muted">#@item.Sequence</span><strong>@item.Title</strong><p>@item.Description</p></li>
                        }
                    </ol>
                }
            </section>
        </div>
    }
</div>

@code {
    [Parameter] public Guid GameId { get; set; }

    private readonly List<EventFeedItem> _eventFeed = new();
    private readonly HashSet<int> _selectedDiceIndexes = new();
    private GameStateDto? _game;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;
    private bool _busy;
    private string? _error;

    private bool IsRunning => string.Equals(_game?.Status, "Running", StringComparison.OrdinalIgnoreCase);
    private bool IsSetup => string.Equals(_game?.Status, "Setup", StringComparison.OrdinalIgnoreCase);
    private bool HasPendingDecision => _game?.PendingDecision is not null;
    private string? CurrentPhase => _game?.CurrentTurn?.Phase;
    private bool IsAwaitingNextTurnStart => _game?.CurrentTurn is null || IsPhase("Finished");
    private int? CurrentPlayerIdFromIndex => _game is null || _game.CurrentPlayerIndex < 0 || _game.CurrentPlayerIndex >= _game.Players.Count
        ? null
        : _game.Players[_game.CurrentPlayerIndex].PlayerId;
    private int? CurrentActorId => IsAwaitingNextTurnStart
        ? CurrentPlayerIdFromIndex
        : _game?.CurrentTurn?.CurrentPlayerId ?? CurrentPlayerIdFromIndex;
    private bool IsLocalActor => Session.PlayerId is not null && CurrentActorId == Session.PlayerId;

    private string LocalPlayerLabel => Session.PlayerId is null ? "Unknown player" : PlayerName(Session.PlayerId.Value);
    private string ActiveTurnLabel => CurrentActorId is null ? "No active turn" : PlayerName(CurrentActorId.Value);
    private string PhaseLabel => string.IsNullOrWhiteSpace(CurrentPhase) ? "No phase" : CurrentPhase;
    private string RollsLabel => _game?.CurrentTurn is null ? "No dice yet" : $"{_game.CurrentTurn.RollCountUsed}/{_game.CurrentTurn.MaxRolls}";

    private string ActorPillText
    {
        get
        {
            if (CurrentActorId is null) return "No active turn yet";
            if (IsLocalActor) return "Your turn";
            return $"Waiting for {PlayerName(CurrentActorId.Value)}";
        }
    }

    private bool IsSelectDiceToRerollDecision =>
        _game?.PendingDecision is not null &&
        string.Equals(_game.PendingDecision.DecisionType, "SelectDiceToReroll", StringComparison.OrdinalIgnoreCase) &&
        _game.CurrentTurn is not null &&
        _game.PendingDecision.PlayerId == _game.CurrentTurn.CurrentPlayerId;

    private bool CanInitialize => IsSetup;
    private bool CanBeginTurn => IsRunning && !HasPendingDecision && IsLocalActor && IsAwaitingNextTurnStart;
    private bool CanRollDice => IsRunning && !HasPendingDecision && IsLocalActor && IsPhase("Rolling") && _game?.CurrentTurn?.RollCountUsed == 0;
    private bool CanRerollStep => IsRunning && IsLocalActor && IsPhase("Rolling") && _game?.CurrentTurn?.RollCountUsed > 0 && _game.CurrentTurn.RollCountUsed < _game.CurrentTurn.MaxRolls && (!HasPendingDecision || IsSelectDiceToRerollDecision);
    private bool CanSelectDiceForReroll => CanRerollStep && _game?.CurrentTurn?.DiceResolved == false;
    private bool CanRerollSelected => CanSelectDiceForReroll && _selectedDiceIndexes.Count > 0 && _selectedDiceIndexes.All(index => _game!.CurrentTurn!.Dice.Any(die => die.Index == index && !die.IsLocked));
    private bool CanFinalizeDice => IsRunning && IsLocalActor && IsPhase("Rolling") && _game?.CurrentTurn?.RollCountUsed > 0 && _game.CurrentTurn.DiceResolved == false && (!HasPendingDecision || IsSelectDiceToRerollDecision);
    private bool CanUseMarketActions => IsRunning && !HasPendingDecision && IsLocalActor && IsPhase("Purchase");
    private bool CanEndTurn => CanUseMarketActions;
    private bool CanAdvancePlayer => IsRunning && !HasPendingDecision && _game?.CurrentTurn is not null && IsPhase("Finished");
    private bool CanAnswerLeaveTokyoDecision => _game?.PendingDecision is not null && Session.PlayerId == _game.PendingDecision.PlayerId && string.Equals(_game.PendingDecision.DecisionType, "LeaveTokyo", StringComparison.OrdinalIgnoreCase);

    private string SmartActionTitle
    {
        get
        {
            if (_game?.WinnerPlayerId is not null) return "Game finished";
            if (CanInitialize) return "Initialize game";
            if (CanBeginTurn) return "Begin your turn";
            if (CanRollDice) return "Roll dice";
            if (CanRerollSelected) return "Reroll selected dice";
            if (CanSelectDiceForReroll) return "Choose dice or finalize";
            if (CanFinalizeDice) return "Finalize dice";
            if (CanUseMarketActions) return "Buy cards or end turn";
            if (CanAdvancePlayer) return "Advance to next player";
            if (_game?.PendingDecision is not null) return $"Waiting for {PlayerName(_game.PendingDecision.PlayerId)}";
            if (CurrentActorId is not null && !IsLocalActor) return $"Waiting for {PlayerName(CurrentActorId.Value)}";
            return "Waiting";
        }
    }

    private string SmartActionDescription
    {
        get
        {
            if (_game?.WinnerPlayerId is not null) return "The match has a winner.";
            if (CanInitialize) return "Start the match state and deal the initial market.";
            if (CanBeginTurn) return "Start the active monster's turn.";
            if (CanRollDice) return "Make the first roll of this turn.";
            if (CanRerollSelected) return "Reroll the dice you selected below, or finalize if you want to keep the current result.";
            if (CanSelectDiceForReroll) return "Click dice below to select them for reroll, or finalize the current result.";
            if (CanFinalizeDice) return "Resolve the current dice result and move to the next step.";
            if (CanUseMarketActions) return "Buy cards from the market, refresh the market, or end and advance the turn.";
            if (CanAdvancePlayer) return "The current turn is finished. Move to the next monster.";
            if (_game?.PendingDecision is not null) return "Another decision must be answered before the game can continue.";
            if (CurrentActorId is not null && !IsLocalActor) return $"This session controls {LocalPlayerLabel}. Use Control active monster to control {PlayerName(CurrentActorId.Value)} for local testing.";
            return "Refresh the game if you expect a new state.";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.LoadAsync();
        if (Session.GameId is null || Session.GameId != GameId)
        {
            Session.RememberGame(GameId);
            await Session.SaveAsync();
        }

        await RefreshAsync();
        await RefreshEventsAsync();
        _cts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = PollAsync(_cts.Token);
    }

    private bool IsPhase(string phase) => string.Equals(CurrentPhase, phase, StringComparison.OrdinalIgnoreCase);

    private string MonsterCardClass(PlayerDto player)
    {
        var classes = new List<string> { "monster-card", "display-card" };

        if (player.PlayerId == Session.PlayerId)
        {
            classes.Add("selected");
            classes.Add("local-monster");
        }

        if (player.PlayerId == CurrentActorId)
        {
            classes.Add("active-monster");
        }

        if (IsTokyoOccupant(player))
        {
            classes.Add("tokyo-monster");
        }

        if (!player.IsAlive)
        {
            classes.Add("eliminated-monster");
        }

        return string.Join(" ", classes);
    }

    private bool IsTokyoOccupant(PlayerDto player) =>
        _game?.Tokyo.CityOccupantId == player.PlayerId || _game?.Tokyo.BayOccupantId == player.PlayerId;

    private RenderFragment RenderTokyoSlot(string title, int? playerId, bool isEnabled) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", $"tokyo-slot {(isEnabled ? string.Empty : "disabled-slot")}");
        builder.OpenElement(sequence++, "h3");
        builder.AddContent(sequence++, title);
        builder.CloseElement();

        if (!isEnabled)
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "muted");
            builder.AddContent(sequence++, "Disabled for this player count");
            builder.CloseElement();
        }
        else if (playerId is null || _game is null)
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "muted");
            builder.AddContent(sequence++, "Empty");
            builder.CloseElement();
        }
        else
        {
            var player = _game.Players.FirstOrDefault(p => p.PlayerId == playerId.Value);
            var monster = MonsterCatalog.FindByName(player?.MonsterName);
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "tokyo-occupant");
            builder.AddAttribute(sequence++, "style", $"--accent:{monster.Accent}");
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "monster-emoji");
            builder.AddContent(sequence++, monster.Emoji);
            builder.CloseElement();
            builder.OpenElement(sequence++, "strong");
            builder.AddContent(sequence++, player?.MonsterName ?? $"Player {playerId}");
            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private string PlayerName(int playerId) => _game?.Players.FirstOrDefault(player => player.PlayerId == playerId)?.MonsterName ?? $"Player {playerId}";

    private static string DieIcon(string face) => face switch
    {
        "One" => "1",
        "Two" => "2",
        "Three" => "3",
        "Energy" => "⚡",
        "Heal" => "❤",
        "Attack" => "🗯",
        _ => face
    };

    private async Task ControlPlayerAsync(int playerId)
    {
        Session.PlayerId = playerId;
        _selectedDiceIndexes.Clear();
        await Session.SaveAsync();
        await RefreshAsync();
    }

    private void ToggleDieSelection(int dieIndex)
    {
        if (!_selectedDiceIndexes.Add(dieIndex))
        {
            _selectedDiceIndexes.Remove(dieIndex);
        }
    }

    private void ClearSelectedDice() => _selectedDiceIndexes.Clear();

    private async Task PollAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (_timer is not null && await _timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    await RefreshAsync();
                    await RefreshEventsAsync();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task RefreshAsync()
    {
        try
        {
            _game = await ApiClient.GetGameAsync(GameId);
            PruneSelectedDice();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void PruneSelectedDice()
    {
        if (_game?.CurrentTurn is null || !CanSelectDiceForReroll)
        {
            _selectedDiceIndexes.Clear();
            return;
        }

        var validIndexes = _game.CurrentTurn.Dice.Where(die => !die.IsLocked).Select(die => die.Index).ToHashSet();
        _selectedDiceIndexes.RemoveWhere(index => !validIndexes.Contains(index));
    }

    private async Task RefreshEventsAsync()
    {
        try
        {
            var cursor = await ApiClient.GetEventsAsync(GameId, Session.LastEventSequence);
            if (cursor is null)
            {
                return;
            }

            foreach (var envelope in cursor.Events)
            {
                if (!_eventFeed.Any(item => item.Sequence == envelope.EventSequence))
                {
                    _eventFeed.Add(EventFeedItem.From(envelope, PlayerName));
                }
            }

            Session.LastEventSequence = cursor.CurrentEventSequence;
            await Session.SaveAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ExecuteAsync(Func<Task<ApiCommandResultDto>> command)
    {
        _busy = true;
        _error = null;

        try
        {
            var result = await command();
            if (!result.Success)
            {
                _error = result.Error;
            }

            _game = result.GameState;
            _selectedDiceIndexes.Clear();
            foreach (var newEvent in result.NewEvents)
            {
                _eventFeed.Add(EventFeedItem.From(Session.LastEventSequence + 1, newEvent, PlayerName));
                Session.LastEventSequence++;
            }

            if (result.CurrentEventSequence > Session.LastEventSequence)
            {
                Session.LastEventSequence = result.CurrentEventSequence;
            }

            await Session.SaveAsync();
            await RefreshEventsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private Task InitializeAsync() => ExecuteAsync(() => ApiClient.InitializeGameAsync(GameId));
    private Task BeginTurnAsync() => ExecuteAsync(() => ApiClient.BeginTurnAsync(GameId, new ActorRequest(Session.PlayerId)));
    private Task RollDiceAsync() => ExecuteAsync(() => ApiClient.RollDiceAsync(GameId, new ActorRequest(Session.PlayerId)));
    private Task RerollSelectedDiceAsync() => ExecuteAsync(() => ApiClient.RerollDiceAsync(GameId, new RerollDiceRequest(Session.PlayerId, _selectedDiceIndexes.OrderBy(index => index).ToArray())));
    private Task FinalizeDiceAsync() => ExecuteAsync(() => ApiClient.FinalizeDiceAsync(GameId, new ActorRequest(Session.PlayerId)));
    private Task BuyFaceUpCardAsync(int slotIndex) => ExecuteAsync(() => ApiClient.BuyFaceUpCardAsync(GameId, new BuyFaceUpCardRequest(Session.PlayerId, slotIndex)));
    private Task RefreshMarketAsync() => ExecuteAsync(() => ApiClient.RefreshMarketAsync(GameId, new ActorRequest(Session.PlayerId)));

    private Task ChooseLeaveTokyoAsync(bool leaveTokyo)
    {
        if (_game?.PendingDecision is null)
        {
            return Task.CompletedTask;
        }

        return ExecuteAsync(() => ApiClient.ChooseLeaveTokyoAsync(GameId, new ChooseLeaveTokyoRequest(_game.PendingDecision.PlayerId, leaveTokyo)));
    }

    private Task EndTurnAsync() => ExecuteAsync(() => ApiClient.EndTurnAsync(GameId, new ActorRequest(Session.PlayerId)));

    private async Task EndTurnAndAdvanceAsync()
    {
        await EndTurnAsync();

        if (_error is null && CanAdvancePlayer)
        {
            await AdvancePlayerAsync();
        }
    }

    private Task AdvancePlayerAsync() => ExecuteAsync(() => ApiClient.AdvancePlayerAsync(GameId, new ActorRequest(Session.PlayerId)));

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _timer?.Dispose();
    }

    private sealed record EventFeedItem(long Sequence, string Title, string Description)
    {
        public static EventFeedItem From(GameEventEnvelopeDto envelope, Func<int, string> playerName) => From(envelope.EventSequence, envelope.Event, playerName);

        public static EventFeedItem From(long sequence, System.Text.Json.JsonElement json, Func<int, string> playerName)
        {
            var eventName = ReadString(json, "eventName") ?? "GameEvent";
            var cleanName = eventName.Replace("Event", string.Empty);
            var playerId = ReadInt(json, "playerId");
            var sourcePlayerId = ReadInt(json, "sourcePlayerId");
            var targetPlayerId = ReadInt(json, "targetPlayerId");
            var amount = ReadInt(json, "amount");
            var reason = ReadString(json, "reason");
            var cardName = ReadString(json, "cardName");
            var slot = ReadString(json, "slot");

            return eventName switch
            {
                "TurnStartedEvent" => new(sequence, "Turn started", $"{Name(playerName, playerId)} started their turn."),
                "DiceRolledEvent" => new(sequence, "Dice rolled", $"{Name(playerName, playerId)} rolled {FormatFaces(json)} on roll {ReadInt(json, "rollNumber") ?? 1}."),
                "DiceFinalizedEvent" => new(sequence, "Dice resolved", $"{Name(playerName, playerId)} resolved dice: {FormatDiceSummary(json)}."),
                "DamageDealtEvent" => new(sequence, "Damage dealt", $"{Name(playerName, sourcePlayerId)} dealt {amount ?? 0} damage to {Name(playerName, targetPlayerId)}{FormatSuffix(ReadString(json, "damageKind"))}."),
                "DamageCanceledEvent" => new(sequence, "Damage canceled", $"Damage against {Name(playerName, targetPlayerId ?? playerId)} was canceled{FormatSuffix(reason)}."),
                "PlayerHealedEvent" => new(sequence, "Healing", $"{Name(playerName, playerId)} healed {amount ?? 0} HP{FormatSuffix(reason)}."),
                "TokyoEnteredEvent" => new(sequence, "Tokyo entered", $"{Name(playerName, playerId)} entered {FormatTokyoSlot(slot)}."),
                "TokyoLeftEvent" => new(sequence, "Tokyo left", $"{Name(playerName, playerId)} left {FormatTokyoSlot(slot)}."),
                "CardBoughtEvent" => new(sequence, "Card bought", $"{Name(playerName, playerId)} bought {cardName ?? "a card"} for {ReadInt(json, "cost") ?? ReadInt(json, "costSpent") ?? 0} energy."),
                "MarketRefreshedEvent" => new(sequence, "Market refreshed", playerId is null ? "The market was refreshed." : $"{Name(playerName, playerId)} refreshed the market."),
                "StatusTokensAddedEvent" => new(sequence, "Status tokens", $"{Name(playerName, sourcePlayerId)} gave {FormatStatusTokens(json, added: true)} to {Name(playerName, targetPlayerId)}."),
                "StatusTokensRemovedEvent" => new(sequence, "Status tokens removed", $"{FormatStatusTokens(json, added: false)} were removed from {Name(playerName, targetPlayerId ?? playerId)}."),
                "KeepCardDiscardedEvent" => new(sequence, "Card discarded", $"{Name(playerName, playerId)} discarded {cardName ?? "a keep card"}."),
                "GameEndedEvent" => FormatGameEnded(sequence, json, playerName, reason),
                _ => new EventFeedItem(sequence, SplitTitle(cleanName), FormatFallback(json, playerName))
            };
        }

        private static EventFeedItem FormatGameEnded(long sequence, System.Text.Json.JsonElement json, Func<int, string> playerName, string? reason)
        {
            var winnerPlayerId = ReadInt(json, "winnerPlayerId");
            return winnerPlayerId is null
                ? new EventFeedItem(sequence, "Game ended", $"The game ended without a winner{FormatSuffix(reason)}.")
                : new EventFeedItem(sequence, "Game ended", $"{Name(playerName, winnerPlayerId)} won the game{FormatSuffix(reason)}.");
        }

        private static string FormatFallback(System.Text.Json.JsonElement json, Func<int, string> playerName)
        {
            var parts = new List<string>();
            Add(parts, ReadInt(json, "playerId"), "Player", playerName);
            Add(parts, ReadInt(json, "sourcePlayerId"), "Source", playerName);
            Add(parts, ReadInt(json, "targetPlayerId"), "Target", playerName);
            Add(parts, ReadInt(json, "amount"), "Amount");
            Add(parts, ReadString(json, "cardName"));
            Add(parts, ReadString(json, "reason"));
            return parts.Count == 0 ? json.ToString() : string.Join(" • ", parts);
        }

        private static string FormatFaces(System.Text.Json.JsonElement json)
        {
            if (!json.TryGetProperty("faces", out var faces) || faces.ValueKind != System.Text.Json.JsonValueKind.Array)
            {
                return "dice";
            }

            var formatted = faces.EnumerateArray()
                .Select(face => face.ValueKind == System.Text.Json.JsonValueKind.String ? FaceIcon(face.GetString()) : "?")
                .ToArray();
            return formatted.Length == 0 ? "dice" : string.Join(" ", formatted);
        }

        private static string FormatDiceSummary(System.Text.Json.JsonElement json)
        {
            if (!json.TryGetProperty("summary", out var summary) || summary.ValueKind != System.Text.Json.JsonValueKind.Object)
            {
                return "result applied";
            }

            var parts = new List<string>();
            AddCount(parts, ReadInt(summary, "attackCount"), "attack");
            AddCount(parts, ReadInt(summary, "energyCount"), "energy");
            AddCount(parts, ReadInt(summary, "heartCount"), "heal");
            AddCount(parts, ReadInt(summary, "victoryPointsFromNumbers"), "VP");
            return parts.Count == 0 ? "no direct effect" : string.Join(", ", parts);
        }

        private static string FormatStatusTokens(System.Text.Json.JsonElement json, bool added)
        {
            var parts = new List<string>();
            AddCount(parts, ReadInt(json, added ? "poisonTokensAdded" : "poisonTokensRemoved"), "poison");
            AddCount(parts, ReadInt(json, added ? "shrinkTokensAdded" : "shrinkTokensRemoved"), "shrink");
            return parts.Count == 0 ? "status tokens" : string.Join(" and ", parts);
        }

        private static string FaceIcon(string? face) => face switch
        {
            "One" => "1",
            "Two" => "2",
            "Three" => "3",
            "Energy" => "⚡",
            "Heal" => "❤",
            "Attack" => "💥",
            _ => face ?? "?"
        };

        private static string FormatTokyoSlot(string? slot) => slot switch
        {
            "City" => "Tokyo City",
            "Bay" => "Tokyo Bay",
            _ => "Tokyo"
        };

        private static string FormatSuffix(string? value) => string.IsNullOrWhiteSpace(value) ? string.Empty : $" ({value})";
        private static string Name(Func<int, string> playerName, int? playerId) => playerId is null ? "Unknown monster" : playerName(playerId.Value);
        private static string SplitTitle(string value) => string.Concat(value.SelectMany((character, index) => index > 0 && char.IsUpper(character) ? new[] { ' ', character } : new[] { character }));

        private static void AddCount(List<string> parts, int? value, string label)
        {
            if (value is > 0) parts.Add($"{value} {label}");
        }

        private static void Add(List<string> parts, int? value, string label)
        {
            if (value is not null) parts.Add($"{label} {value}");
        }

        private static void Add(List<string> parts, int? value, string label, Func<int, string> playerName)
        {
            if (value is not null) parts.Add($"{label}: {playerName(value.Value)}");
        }

        private static void Add(List<string> parts, string? value)
        {
            if (!string.IsNullOrWhiteSpace(value)) parts.Add(value);
        }

        private static string? ReadString(System.Text.Json.JsonElement json, string propertyName) =>
            json.TryGetProperty(propertyName, out var value) && value.ValueKind == System.Text.Json.JsonValueKind.String ? value.GetString() : null;

        private static int? ReadInt(System.Text.Json.JsonElement json, string propertyName) =>
            json.TryGetProperty(propertyName, out var value) && value.ValueKind == System.Text.Json.JsonValueKind.Number && value.TryGetInt32(out var number) ? number : null;
    }
}
