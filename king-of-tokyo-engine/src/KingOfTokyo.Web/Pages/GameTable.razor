    private Task AdvancePlayerAsync() => ExecuteAsync(() => ApiClient.AdvancePlayerAsync(GameId, new ActorRequest(Session.PlayerId)));
    private Task PeekTopDeckCardAsync() => ExecuteAsync(() => ApiClient.PeekTopDeckCardAsync(GameId, new ActorRequest(Session.PlayerId)));
    private Task BuyPeekedTopDeckCardAsync() => ExecuteAsync(() => ApiClient.BuyPeekedTopDeckCardAsync(GameId, new ActorRequest(Session.PlayerId)));
    private Task DeclinePeekedTopDeckCardAsync() => ExecuteAsync(() => ApiClient.DeclinePeekedTopDeckCardAsync(GameId, new ActorRequest(Session.PlayerId)));
    private Task ActivateRapidHealingAsync() => ExecuteAsync(() => ApiClient.ActivateRapidHealingAsync(GameId, new ActorRequest(Session.PlayerId)));
    private Task ActivateWingsAsync() => ExecuteAsync(() => ApiClient.ActivateWingsAsync(GameId, new ActorRequest(Session.PlayerId)));
