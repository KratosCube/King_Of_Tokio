@page "/games/{GameId:guid}"
@implements IDisposable
@inject ApiClient ApiClient
@inject ClientSessionState Session

<div class="card game-hero">
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="status-pill danger-pill">@_error</p>
    }

    @if (_game is null)
    {
        <p class="muted">Loading game...</p>
    }
    else
    {
        @if (_game.WinnerPlayerId is not null)
        {
            <p class="status-pill">Winner: @PlayerName(_game.WinnerPlayerId.Value) — @_game.WinnerReason</p>
        }

        <div class="game-grid">
            <section class="panel">
                <h2>Monsters</h2>
                <div class="monster-grid stacked-monsters">
                    @foreach (var player in _game.Players)
                    {
                        var monster = MonsterCatalog.FindByName(player.MonsterName);
                        var playerId = player.PlayerId;
                        <article class="@MonsterCardClass(player)" style="--accent:@monster.Accent">
                            <span class="monster-emoji">@monster.Emoji</span>
                            <strong>@player.MonsterName</strong>
                            <small>Player #@player.PlayerId • @player.TokyoSlot</small>
                            <div class="monster-badge-row">
                                @if (player.PlayerId == Session.PlayerId)
                                {
                                    <span class="status-pill">You control</span>
                                }
                                @if (player.PlayerId == CurrentActorId)
                                {
                                    <span class="status-pill turn-pill">Active turn</span>
                                }
                                @if (player.PlayerId == PendingDecisionPlayerId)
                                {
                                    <span class="status-pill danger-pill">Decision</span>
                                }
                                @if (IsTokyoOccupant(player))
                                {
                                    <span class="status-pill tokyo-pill">In Tokyo</span>
                                }
                                @if (!player.IsAlive)
                                {
                                    <span class="status-pill danger-pill">Eliminated</span>
                                }
                            </div>
                            <div class="monster-stats">
                                <span>HP @player.Health/@player.MaxHealth</span>
                                <span>VP @player.VictoryPoints</span>
                                <span>⚡ @player.Energy</span>
                            </div>
                            <PlayerStatusTokens Status="player.Status" />
                            <PlayerKeepCards OwnerPlayerId="@player.PlayerId"
                                             Cards="player.KeepCards"
                                             OnCardClicked="HandleKeepCardClickedAsync"
                                             IsActionAvailable="@(card => IsKeepCardActionAvailable(playerId, card))"
                                             IsSelected="@(card => IsKeepCardSelected(playerId, card))" />
                        </article>
                    }
                </div>
            </section>

            <section class="panel">
                <h2>Tokyo</h2>
                <div class="tokyo-board">
                    @RenderTokyoSlot("Tokyo City", _game.Tokyo.CityOccupantId, true)
                    @RenderTokyoSlot("Tokyo Bay", _game.Tokyo.BayOccupantId, _game.Tokyo.BayEnabled)
                </div>

                @if (HasPendingDecision)
                {
                    <section class="decision-panel">
                        <h2>Pending decision</h2>
                        <p><strong>@_game.PendingDecision!.DecisionType</strong> <span class="muted">for @PlayerName(_game.PendingDecision.PlayerId)</span></p>
                        <p class="muted">@PendingDecisionDescription</p>
                        @if (IsPeekTopDeckCardPurchaseDecision && IsLocalDecisionActor && PeekedTopDeckCard is not null)
                        {
                            <div class="special-card-action-card revealed-card-action-card">
                                <div class="revealed-card-layout">
                                    <div class="card-art-frame compact-card-art revealed-card-art">
                                        <img src="@CardImagePath(PeekedTopDeckCard.CardId)" alt="@PeekedTopDeckCard.CardName card art" loading="lazy" onerror="this.closest('.revealed-card-art')?.classList.add('missing-card-art'); this.remove();" />
                                        <div class="card-art-fallback">
                                            <strong>@PeekedTopDeckCard.CardName</strong>
                                            <small>@PeekedTopDeckCard.CardType • Cost @PeekedTopDeckCard.EffectiveCost</small>
                                        </div>
                                    </div>
                                    <div>
                                        <strong>@PeekedTopDeckCard.CardName</strong>
                                        <small>@PeekedTopDeckCard.CardType • Cost @PeekedTopDeckCard.EffectiveCost</small>
                                        <p>@PeekedTopDeckCard.Description</p>
                                        <div class="actions compact-actions">
                                            <button class="btn btn-primary" @onclick="BuyPeekedTopDeckCardAsync" disabled="@_busy">Buy top card</button>
                                            <button class="btn btn-secondary" @onclick="DeclinePeekedTopDeckCardAsync" disabled="@_busy">Skip</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </section>
                }

                <h2>Dice</h2>
                @if (_game.CurrentTurn?.Dice.Count > 0)
                {
                    <div class="dice-row">
                        @foreach (var die in _game.CurrentTurn.Dice)
                        {
                            var isSelected = _selectedDiceIndexes.Contains(die.Index);
                            <button type="button" class="die-button @(isSelected ? "selected" : null)" disabled="@(_busy || die.IsLocked || !CanSelectDiceForReroll)" @onclick="() => ToggleDieSelection(die.Index)">
                                <span class="die-face @(die.IsLocked ? "locked" : null)">@DieIcon(die.CurrentFace)</span>
                                <small>@(die.IsLocked ? "locked" : isSelected ? "reroll" : string.Empty)</small>
                            </button>
                        }
                    </div>
                    <div class="actions compact-actions">
                        <button class="btn btn-secondary" @onclick="ClearSelectedDice" disabled="@(_busy || _selectedDiceIndexes.Count == 0)">Clear dice selection</button>
                    </div>
                }
                else
                {
                    <div class="placeholder-box">Dice will appear here after rolling.</div>
                }

                @if (SelectedActionCard is not null || _mimicTargetSelectionActive)
                {
                    <section class="special-card-action-card selected-keep-action-panel">
                        @if (SelectedActionCard is not null)
                        {
                            <div class="selected-keep-action-header">
                                <strong>@SelectedActionCard.Name</strong>
                                @if (SelectedActionCard.MimicTarget is not null)
                                {
                                    <small>Mimicking @SelectedActionCard.MimicTarget.CardName from @PlayerName(SelectedActionCard.MimicTarget.OwnerPlayerId)</small>
                                }
                                else
                                {
                                    <small>@SelectedActionCard.CardType • Cost @SelectedActionCard.Cost</small>
                                }
                            </div>
                        }

                        @if (_mimicTargetSelectionActive)
                        {
                            <p class="status-pill">Mimic target selection</p>
                            <p class="muted">Click a keep card owned by another monster to imitate it.</p>
                        }

                        <div class="actions compact-actions">
                            @if (SelectedCanUseMadeInALab)
                            {
                                <button class="btn btn-secondary" @onclick="PeekTopDeckCardAsync" disabled="@_busy">Use Made in a Lab</button>
                            }
                            @if (SelectedCanUseRapidHealing)
                            {
                                <button class="btn btn-secondary" @onclick="ActivateRapidHealingAsync" disabled="@_busy">Heal 1 for 2⚡</button>
                            }
                            @if (SelectedCanUseWings)
                            {
                                <button class="btn btn-secondary" @onclick="ActivateWingsAsync" disabled="@_busy">Cancel damage for 2⚡</button>
                            }
                            @if (SelectedCanUseMimic)
                            {
                                <button class="btn btn-secondary" @onclick="BeginMimicTargetSelection" disabled="@_busy">Choose imitation target</button>
                            }
                        </div>

                        @if (SelectedCanUseHealingRay)
                        {
                            <div class="healing-ray-inline-controls">
                                <small>Spend available heart dice to heal another monster.</small>
                                <div class="actions compact-actions">
                                    <select @bind="_healingRayTargetPlayerId" disabled="@_busy">
                                        @foreach (var target in HealingRayTargets)
                                        {
                                            <option value="@target.PlayerId">@target.MonsterName (@target.Health/@target.MaxHealth HP, ⚡ @target.Energy)</option>
                                        }
                                    </select>
                                    <input type="number" min="1" max="@AvailableHealingRayHearts" @bind="_healingRayAmount" disabled="@_busy" />
                                    <button class="btn btn-secondary" @onclick="ActivateHealingRayAsync" disabled="@(_busy || _healingRayTargetPlayerId < 0 || _healingRayAmount <= 0)">Heal with ray</button>
                                </div>
                            </div>
                        }

                        <div class="actions compact-actions">
                            <button class="btn btn-secondary" @onclick="ClearSelectedKeepAction" disabled="@_busy">Close card action</button>
                        </div>
                    </section>
                }
            </section>

            <section class="panel market-panel">
                <h2>Market</h2>
                <div class="market-list">
                    @foreach (var card in _game.Market.FaceUpCards.Select((value, index) => new { value, index }))
                    {
                        <article class="market-card">
                            @if (card.value is null)
                            {
                                <p class="muted">Slot @card.index: empty</p>
                            }
                            else
                            {
                                <div class="market-card-header">
                                    <h3>@card.value.Name</h3>
                                    <span class="market-cost">⚡ @card.value.Cost</span>
                                </div>
                                <small class="market-card-type">@card.value.CardType</small>
                                <p>@card.value.Description</p>
                                <button class="btn btn-primary" @onclick="() => BuyFaceUpCardAsync(card.index)" disabled="@(_busy || !CanUseMarketActions)">Buy</button>
                            }
                        </article>
                    }
                </div>
                <div class="market-footer">
                    <p class="muted">Deck: @_game.Market.DrawPileCount • Discard: @_game.Market.DiscardPileCount</p>
                    <button class="btn btn-secondary" @onclick="RefreshMarketAsync" disabled="@(_busy || !CanUseMarketActions)">Refresh market</button>
                </div>
            </section>
        </div>

        <div class="grid-2 lower-game-grid">
            <section class="panel next-action-panel">
                <h2>Next action</h2>
                <p class="status-pill">@SmartActionTitle</p>
                <p class="muted">@SmartActionDescription</p>
                <div class="actions">
                    @if (CanAnswerLeaveTokyoDecision)
                    {
                        <button class="btn btn-primary" @onclick="() => ChooseLeaveTokyoAsync(true)" disabled="@_busy">Leave Tokyo</button>
                        <button class="btn btn-secondary" @onclick="() => ChooseLeaveTokyoAsync(false)" disabled="@_busy">Stay in Tokyo</button>
                    }
                    else if (CanControlDecisionActor)
                    {
                        <button class="btn btn-primary" @onclick="ControlDecisionPlayerAsync" disabled="@_busy">Control decision monster</button>
                        <button class="btn btn-secondary" @onclick="RefreshAllAsync" disabled="@_busy">Refresh</button>
                    }
                    else if (CanRollDice)
                    {
                        <button class="btn btn-primary" @onclick="RollDiceAsync" disabled="@_busy">Roll dice</button>
                    }
                    else if (CanRerollSelected)
                    {
                        <button class="btn btn-primary" @onclick="RerollSelectedDiceAsync" disabled="@_busy">Reroll selected dice</button>
                        <button class="btn btn-secondary" @onclick="FinalizeDiceAsync" disabled="@_busy">Finalize instead</button>
                    }
                    else if (CanSelectDiceForReroll)
                    {
                        <button class="btn btn-secondary" disabled>Select dice to reroll</button>
                        <button class="btn btn-primary" @onclick="FinalizeDiceAsync" disabled="@_busy">Finalize dice</button>
                    }
                    else if (CanFinalizeDice)
                    {
                        <button class="btn btn-primary" @onclick="FinalizeDiceAsync" disabled="@_busy">Finalize dice</button>
                    }
                    else if (CanUseMarketActions)
                    {
                        <button class="btn btn-primary" @onclick="EndTurnAndAdvanceAsync" disabled="@_busy">End turn</button>
                        <button class="btn btn-secondary" @onclick="RefreshMarketAsync" disabled="@_busy">Refresh market</button>
                    }
                    else if (AllowDevPlayerControl && CurrentActorId is not null && !IsLocalActor)
                    {
                        <button class="btn btn-primary" @onclick="() => ControlPlayerAsync(CurrentActorId.Value)" disabled="@_busy">Control active monster</button>
                        <button class="btn btn-secondary" @onclick="RefreshAllAsync" disabled="@_busy">Refresh</button>
                    }
                    else
                    {
                        <button class="btn btn-secondary" @onclick="RefreshAllAsync" disabled="@_busy">Refresh</button>
                    }
                </div>
            </section>

            <section class="panel developer-panel">
                <details>
                    <summary class="dev-tools-summary">
                        <span>Debug commands</span>
                        <small>@(AllowDevPlayerControl ? "Local single-browser tools" : "Player switching disabled for lobby multiplayer")</small>
                    </summary>
                    <p class="muted">Current local player id: @(Session.PlayerId?.ToString() ?? "unknown")</p>
                    @if (AllowDevPlayerControl)
                    {
                        <div class="actions compact-actions">
                            @foreach (var player in _game.Players)
                            {
                                <button class="btn btn-secondary" @onclick="() => ControlPlayerAsync(player.PlayerId)" disabled="@(_busy || Session.PlayerId == player.PlayerId)">Control @player.MonsterName</button>
                            }
                        </div>
                    }
                    <div class="actions">
                        <button class="btn btn-secondary" @onclick="InitializeAsync" disabled="@(_busy || !CanInitialize)">Initialize</button>
                        <button class="btn btn-secondary" @onclick="BeginTurnAsync" disabled="@(_busy || !CanBeginTurn)">Begin turn</button>
                        <button class="btn btn-primary" @onclick="RollDiceAsync" disabled="@(_busy || !CanRollDice)">Roll dice</button>
                        <button class="btn btn-primary" @onclick="FinalizeDiceAsync" disabled="@(_busy || !CanFinalizeDice)">Finalize dice</button>
                        <button class="btn btn-secondary" @onclick="EndTurnAsync" disabled="@(_busy || !CanEndTurn)">End turn</button>
                        <button class="btn btn-secondary" @onclick="AdvancePlayerAsync" disabled="@(_busy || !CanAdvancePlayer)">Advance player</button>
                        <button class="btn btn-secondary" @onclick="RefreshAllAsync" disabled="@_busy">Refresh</button>
                    </div>
                </details>
            </section>

            <section class="panel event-feed-panel">
                <h2>Event feed</h2>
                @if (_eventFeed.Count == 0)
                {
                    <p class="muted">No events yet. Start a turn, roll dice, or buy cards to see the story here.</p>
                }
                else
                {
                    <ol class="event-feed">
                        @foreach (var item in _eventFeed.OrderByDescending(item => item.Sequence).Take(20))
                        {
                            <li><span class="muted">#@item.Sequence</span><strong>@item.Title</strong><p>@item.Description</p></li>
                        }
                    </ol>
                }
            </section>
        </div>
    }
</div>

@code {
    [Parameter] public Guid GameId { get; set; }

    private readonly List<EventFeedItem> _eventFeed = new();
    private readonly HashSet<int> _selectedDiceIndexes = new();
    private GameStateDto? _game;
    private LobbyDto? _sourceLobby;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;
    private bool _busy;
    private string? _error;
    private int _healingRayTargetPlayerId = -1;
    private int _healingRayAmount = 1;
    private int? _selectedActionCardOwnerPlayerId;
    private string? _selectedActionCardId;
    private bool _mimicTargetSelectionActive;

    private const string MadeInALabCardId = "card-made-in-a-lab";
    private const string RapidHealingCardId = "card-rapid-healing";
    private const string WingsCardId = "card-wings";
    private const string MimicCardId = "card-mimic";
    private const string HealingRayCardId = "card-healing-ray";

    private bool IsRunning => string.Equals(_game?.Status, "Running", StringComparison.OrdinalIgnoreCase);
    private bool IsSetup => string.Equals(_game?.Status, "Setup", StringComparison.OrdinalIgnoreCase);
    private bool HasPendingDecision => _game?.PendingDecision is not null;
    private bool HasResolvedLobbyIdentity => _sourceLobby is not null && Session.PlayerToken is not null && Session.PlayerId is not null;
    private bool AllowDevPlayerControl => !HasResolvedLobbyIdentity;
    private string? CurrentPhase => _game?.CurrentTurn?.Phase;
    private bool IsAwaitingNextTurnStart => _game?.CurrentTurn is null || IsPhase("Finished");
    private int? CurrentPlayerIdFromIndex => _game is null || _game.CurrentPlayerIndex < 0 || _game.CurrentPlayerIndex >= _game.Players.Count
        ? null
        : _game.Players[_game.CurrentPlayerIndex].PlayerId;
    private int? CurrentActorId => IsAwaitingNextTurnStart ? CurrentPlayerIdFromIndex : _game?.CurrentTurn?.CurrentPlayerId ?? CurrentPlayerIdFromIndex;
    private int? PendingDecisionPlayerId => _game?.PendingDecision?.PlayerId;
    private bool IsLocalActor => Session.PlayerId is not null && CurrentActorId == Session.PlayerId;
    private bool IsLocalDecisionActor => PendingDecisionPlayerId is not null && Session.PlayerId == PendingDecisionPlayerId;
    private bool CanControlDecisionActor => AllowDevPlayerControl && PendingDecisionPlayerId is not null && !IsLocalDecisionActor;

    private string LocalPlayerLabel => Session.PlayerId is null ? "Unknown player" : PlayerName(Session.PlayerId.Value);
    private PlayerDto? LocalPlayer => Session.PlayerId is null ? null : _game?.Players.FirstOrDefault(player => player.PlayerId == Session.PlayerId.Value);
    private bool IsPeekTopDeckCardPurchaseDecision => _game?.PendingDecision is not null && string.Equals(_game.PendingDecision.DecisionType, "PeekTopDeckCardPurchase", StringComparison.OrdinalIgnoreCase);
    private PeekedCardInfo? PeekedTopDeckCard => ReadPeekedCardInfo();
    private CardDto? SelectedActionCard => GetSelectedActionCard();
    private bool SelectedCanUseMadeInALab => SelectedActionCard is not null && ActionCardProvides(SelectedActionCard, MadeInALabCardId) && CanUseMadeInALab;
    private bool SelectedCanUseRapidHealing => SelectedActionCard is not null && ActionCardProvides(SelectedActionCard, RapidHealingCardId) && CanUseRapidHealing;
    private bool SelectedCanUseWings => SelectedActionCard is not null && ActionCardProvides(SelectedActionCard, WingsCardId) && CanUseWings;
    private bool SelectedCanUseHealingRay => SelectedActionCard is not null && ActionCardProvides(SelectedActionCard, HealingRayCardId) && CanUseHealingRay;
    private bool SelectedCanUseMimic => SelectedActionCard?.CardId == MimicCardId && MimicTargetOptions.Any();
    private bool CanUseMadeInALab => CanUseMarketActions && HasEffectiveLocalKeepCard(MadeInALabCardId) && _game?.Market.DrawPileCount > 0;
    private bool CanUseRapidHealing => CanUseMarketActions && HasEffectiveLocalKeepCard(RapidHealingCardId) && LocalPlayer is { Energy: >= 2 } player && player.Health < player.MaxHealth;
    private bool CanUseWings => IsRunning && IsLocalActor && HasEffectiveLocalKeepCard(WingsCardId) && LocalPlayer is { Energy: >= 2 } player && player.Health < player.MaxHealth && _game?.CurrentTurn is not null;
    private bool CanUseHealingRay => CanUseMarketActions && HasEffectiveLocalKeepCard(HealingRayCardId) && AvailableHealingRayHearts > 0 && HealingRayTargets.Any();
    private int AvailableHealingRayHearts => _game?.CurrentTurn?.Dice.Count(die => IsHeartFace(die.CurrentFace)) ?? 0;
    private IEnumerable<PlayerDto> HealingRayTargets => _game?.Players.Where(player =>
        player.PlayerId != Session.PlayerId &&
        player.IsAlive &&
        player.Health < player.MaxHealth) ?? Enumerable.Empty<PlayerDto>();
    private IEnumerable<MimicTargetOption> MimicTargetOptions => _game?.Players
        .Where(player => player.PlayerId != Session.PlayerId && player.IsAlive)
        .SelectMany(player => player.KeepCards
            .Where(card => card.CardId != MimicCardId)
            .Select(card => new MimicTargetOption(player.PlayerId, card.CardId, card.Name)))
        ?? Enumerable.Empty<MimicTargetOption>();

    private string PendingDecisionDescription
    {
        get
        {
            if (_game?.PendingDecision is null) return "No pending decision.";
            if (CanAnswerLeaveTokyoDecision) return "Tokyo is under attack. Choose whether your monster retreats after taking damage.";
            if (IsPeekTopDeckCardPurchaseDecision) return IsLocalDecisionActor ? "Made in a Lab revealed the top deck card. Buy it or skip it." : "Waiting for the Made in a Lab decision.";
            if (IsSelectDiceToRerollDecision && IsLocalDecisionActor) return "Select dice below and reroll them, or finalize the current dice result.";
            if (AllowDevPlayerControl) return $"{PlayerName(_game.PendingDecision.PlayerId)} must answer this decision. You can switch control in local debug mode.";
            return $"Waiting for {PlayerName(_game.PendingDecision.PlayerId)} in their browser session.";
        }
    }

    private bool IsSelectDiceToRerollDecision =>
        _game?.PendingDecision is not null &&
        string.Equals(_game.PendingDecision.DecisionType, "SelectDiceToReroll", StringComparison.OrdinalIgnoreCase) &&
        _game.CurrentTurn is not null &&
        _game.PendingDecision.PlayerId == _game.CurrentTurn.CurrentPlayerId;

    private bool CanInitialize => IsSetup;
    private bool CanBeginTurn => IsRunning && !HasPendingDecision && IsLocalActor && IsAwaitingNextTurnStart;
    private bool CanRollDice => IsRunning && !HasPendingDecision && IsLocalActor && IsPhase("Rolling") && _game?.CurrentTurn?.RollCountUsed == 0;
    private bool CanRerollStep => IsRunning && IsLocalActor && IsPhase("Rolling") && _game?.CurrentTurn?.RollCountUsed > 0 && _game.CurrentTurn.RollCountUsed < _game.CurrentTurn.MaxRolls && (!HasPendingDecision || IsSelectDiceToRerollDecision);
    private bool CanSelectDiceForReroll => CanRerollStep && _game?.CurrentTurn?.DiceResolved == false;
    private bool CanRerollSelected => CanSelectDiceForReroll && _selectedDiceIndexes.Count > 0 && _selectedDiceIndexes.All(index => _game!.CurrentTurn!.Dice.Any(die => die.Index == index && !die.IsLocked));
    private bool CanFinalizeDice => IsRunning && IsLocalActor && IsPhase("Rolling") && _game?.CurrentTurn?.RollCountUsed > 0 && _game.CurrentTurn.DiceResolved == false && (!HasPendingDecision || IsSelectDiceToRerollDecision);
    private bool CanUseMarketActions => IsRunning && !HasPendingDecision && IsLocalActor && IsPhase("Purchase");
    private bool CanEndTurn => CanUseMarketActions;
    private bool CanAdvancePlayer => IsRunning && !HasPendingDecision && _game?.CurrentTurn is not null && IsPhase("Finished");
    private bool CanAnswerLeaveTokyoDecision => _game?.PendingDecision is not null && Session.PlayerId == _game.PendingDecision.PlayerId && string.Equals(_game.PendingDecision.DecisionType, "LeaveTokyo", StringComparison.OrdinalIgnoreCase);

    private string SmartActionTitle
    {
        get
        {
            if (_game?.WinnerPlayerId is not null) return "Game finished";
            if (CanAnswerLeaveTokyoDecision) return "Answer Tokyo decision";
            if (CanControlDecisionActor) return "Control decision monster";
            if (CanRollDice) return "Roll dice";
            if (CanRerollSelected) return "Reroll selected dice";
            if (CanSelectDiceForReroll) return "Choose dice or finalize";
            if (CanFinalizeDice) return "Finalize dice";
            if (CanUseMarketActions) return "Buy cards or end turn";
            if (_game?.PendingDecision is not null) return $"Waiting for {PlayerName(_game.PendingDecision.PlayerId)}";
            if (CurrentActorId is not null && !IsLocalActor) return $"Waiting for {PlayerName(CurrentActorId.Value)}";
            return "Waiting";
        }
    }

    private string SmartActionDescription
    {
        get
        {
            if (_game?.WinnerPlayerId is not null) return "The match has a winner.";
            if (!HasResolvedLobbyIdentity && _sourceLobby is not null) return "This browser is not matched to a lobby seat. Go back to the lobby and join first.";
            if (CanAnswerLeaveTokyoDecision || CanControlDecisionActor || _game?.PendingDecision is not null) return PendingDecisionDescription;
            if (CanRollDice) return "Make the first roll of this turn.";
            if (CanRerollSelected) return "Reroll the dice you selected below, or finalize if you want to keep the current result.";
            if (CanSelectDiceForReroll) return "Click dice below to select them for reroll, or finalize the current result.";
            if (CanFinalizeDice) return "Resolve the current dice result and move to the next step.";
            if (CanUseMarketActions) return "Buy cards from the market, click keep cards to use their actions, refresh the market, or end your turn.";
            if (CurrentActorId is not null && !IsLocalActor) return $"This browser controls {LocalPlayerLabel}. Waiting for {PlayerName(CurrentActorId.Value)} in their session.";
            return "Waiting for the game state to change.";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.LoadAsync();
        await ResolveLobbyIdentityAsync();
        await RefreshAllAsync();
        _cts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
        _ = PollAsync(_cts.Token);
    }

    private async Task ResolveLobbyIdentityAsync()
    {
        if (Session.LobbyId is null)
        {
            _sourceLobby = null;
            return;
        }

        try
        {
            _sourceLobby = await ApiClient.GetLobbyAsync(Session.LobbyId.Value);
            if (_sourceLobby is null)
            {
                return;
            }

            if (_sourceLobby.GameId is not null && _sourceLobby.GameId.Value == GameId && Session.GameId != GameId)
            {
                Session.RememberGame(GameId);
            }

            if (Session.PlayerToken is not null)
            {
                var seat = _sourceLobby.Seats.FirstOrDefault(seat => seat.PlayerToken == Session.PlayerToken.Value);
                if (seat is not null && Session.PlayerId != seat.PlayerId)
                {
                    Session.PlayerId = seat.PlayerId;
                }
            }

            await Session.SaveAsync();
        }
        catch
        {
            _sourceLobby = null;
        }
    }

    private bool IsPhase(string phase) => string.Equals(CurrentPhase, phase, StringComparison.OrdinalIgnoreCase);

    private bool HasEffectiveLocalKeepCard(string cardId) => LocalPlayer?.KeepCards.Any(card => ActionCardProvides(card, cardId)) == true;

    private static bool ActionCardProvides(CardDto card, string cardId)
    {
        return string.Equals(card.CardId, cardId, StringComparison.OrdinalIgnoreCase) ||
               (string.Equals(card.CardId, MimicCardId, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(card.MimicTarget?.CardId, cardId, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsKeepCardActionAvailable(int ownerPlayerId, CardDto card)
    {
        if (ownerPlayerId == Session.PlayerId)
        {
            return (ActionCardProvides(card, MadeInALabCardId) && CanUseMadeInALab) ||
                   (ActionCardProvides(card, RapidHealingCardId) && CanUseRapidHealing) ||
                   (ActionCardProvides(card, WingsCardId) && CanUseWings) ||
                   (ActionCardProvides(card, HealingRayCardId) && CanUseHealingRay) ||
                   (string.Equals(card.CardId, MimicCardId, StringComparison.OrdinalIgnoreCase) && MimicTargetOptions.Any());
        }

        return _mimicTargetSelectionActive && ownerPlayerId != Session.PlayerId && !string.Equals(card.CardId, MimicCardId, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsKeepCardSelected(int ownerPlayerId, CardDto card)
    {
        return _selectedActionCardOwnerPlayerId == ownerPlayerId && string.Equals(_selectedActionCardId, card.CardId, StringComparison.OrdinalIgnoreCase);
    }

    private CardDto? GetSelectedActionCard()
    {
        if (_game is null || _selectedActionCardOwnerPlayerId is null || string.IsNullOrWhiteSpace(_selectedActionCardId))
        {
            return null;
        }

        return _game.Players
            .FirstOrDefault(player => player.PlayerId == _selectedActionCardOwnerPlayerId.Value)?
            .KeepCards
            .FirstOrDefault(card => string.Equals(card.CardId, _selectedActionCardId, StringComparison.OrdinalIgnoreCase));
    }

    private async Task HandleKeepCardClickedAsync(PlayerKeepCards.KeepCardClickArgs args)
    {
        if (_busy)
        {
            return;
        }

        if (_mimicTargetSelectionActive && args.OwnerPlayerId != Session.PlayerId && !string.Equals(args.Card.CardId, MimicCardId, StringComparison.OrdinalIgnoreCase))
        {
            await SetMimicTargetAsync(args.OwnerPlayerId, args.Card.CardId);
            _mimicTargetSelectionActive = false;
            return;
        }

        if (args.OwnerPlayerId == Session.PlayerId && IsKeepCardActionAvailable(args.OwnerPlayerId, args.Card))
        {
            _selectedActionCardOwnerPlayerId = args.OwnerPlayerId;
            _selectedActionCardId = args.Card.CardId;
            if (string.Equals(args.Card.CardId, MimicCardId, StringComparison.OrdinalIgnoreCase))
            {
                _mimicTargetSelectionActive = true;
            }
            else
            {
                _mimicTargetSelectionActive = false;
            }
        }
    }

    private void BeginMimicTargetSelection()
    {
        _mimicTargetSelectionActive = true;
    }

    private void ClearSelectedKeepAction()
    {
        _selectedActionCardOwnerPlayerId = null;
        _selectedActionCardId = null;
        _mimicTargetSelectionActive = false;
    }

    private string MonsterCardClass(PlayerDto player)
    {
        var classes = new List<string> { "monster-card", "display-card" };
        if (player.PlayerId == Session.PlayerId) classes.Add("selected local-monster");
        if (player.PlayerId == CurrentActorId) classes.Add("active-monster");
        if (player.PlayerId == PendingDecisionPlayerId) classes.Add("decision-monster");
        if (IsTokyoOccupant(player)) classes.Add("tokyo-monster");
        if (!player.IsAlive) classes.Add("eliminated-monster");
        return string.Join(" ", classes);
    }

    private bool IsTokyoOccupant(PlayerDto player) => _game?.Tokyo.CityOccupantId == player.PlayerId || _game?.Tokyo.BayOccupantId == player.PlayerId;

    private RenderFragment RenderTokyoSlot(string title, int? playerId, bool isEnabled) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", $"tokyo-slot {(isEnabled ? string.Empty : "disabled-slot")}");
        builder.OpenElement(sequence++, "h3");
        builder.AddContent(sequence++, title);
        builder.CloseElement();

        if (!isEnabled)
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "muted");
            builder.AddContent(sequence++, "Disabled for this player count");
            builder.CloseElement();
        }
        else if (playerId is null || _game is null)
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "muted");
            builder.AddContent(sequence++, "Empty");
            builder.CloseElement();
        }
        else
        {
            var player = _game.Players.FirstOrDefault(p => p.PlayerId == playerId.Value);
            var monster = MonsterCatalog.FindByName(player?.MonsterName);
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "tokyo-occupant");
            builder.AddAttribute(sequence++, "style", $"--accent:{monster.Accent}");
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "monster-emoji");
            builder.AddContent(sequence++, monster.Emoji);
            builder.CloseElement();
            builder.OpenElement(sequence++, "strong");
            builder.AddContent(sequence++, player?.MonsterName ?? $"Player {playerId}");
            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private string PlayerName(int playerId) => _game?.Players.FirstOrDefault(player => player.PlayerId == playerId)?.MonsterName ?? $"Player {playerId}";

    private static bool IsHeartFace(string face) => string.Equals(face, "Heart", StringComparison.OrdinalIgnoreCase) || string.Equals(face, "Heal", StringComparison.OrdinalIgnoreCase);

    private static string DieIcon(string face) => face.ToUpperInvariant() switch
    {
        "ONE" => "1",
        "TWO" => "2",
        "THREE" => "3",
        "ENERGY" => "⚡",
        "HEAL" or "HEART" => "❤",
        "ATTACK" or "CLAW" => "💥",
        _ => face
    };

    private static string CardImagePath(string cardId) => $"/images/cards/{cardId}.jpg";

    private PeekedCardInfo? ReadPeekedCardInfo()
    {
        var payload = _game?.PendingDecision?.Payload;
        if (payload is null || payload.Value.ValueKind != System.Text.Json.JsonValueKind.Object)
        {
            return null;
        }

        var json = payload.Value;
        return new PeekedCardInfo(
            ReadString(json, "cardId") ?? string.Empty,
            ReadString(json, "cardName") ?? "Top deck card",
            ReadString(json, "description") ?? string.Empty,
            ReadInt(json, "baseCost") ?? 0,
            ReadInt(json, "effectiveCost") ?? 0,
            ReadString(json, "cardType") ?? "Card");
    }

    private static string? ReadString(System.Text.Json.JsonElement json, string propertyName) =>
        json.TryGetProperty(propertyName, out var value) && value.ValueKind == System.Text.Json.JsonValueKind.String ? value.GetString() : null;

    private static int? ReadInt(System.Text.Json.JsonElement json, string propertyName) =>
        json.TryGetProperty(propertyName, out var value) && value.ValueKind == System.Text.Json.JsonValueKind.Number && value.TryGetInt32(out var number) ? number : null;

    private Task ControlDecisionPlayerAsync() => PendingDecisionPlayerId is null ? Task.CompletedTask : ControlPlayerAsync(PendingDecisionPlayerId.Value);

    private async Task ControlPlayerAsync(int playerId)
    {
        if (!AllowDevPlayerControl)
        {
            return;
        }

        Session.PlayerId = playerId;
        _selectedDiceIndexes.Clear();
        ClearSelectedKeepAction();
        await Session.SaveAsync();
        await RefreshAllAsync();
    }

    private void ToggleDieSelection(int dieIndex)
    {
        if (!_selectedDiceIndexes.Add(dieIndex))
        {
            _selectedDiceIndexes.Remove(dieIndex);
        }
    }

    private void ClearSelectedDice() => _selectedDiceIndexes.Clear();

    private async Task PollAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (_timer is not null && await _timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    await ResolveLobbyIdentityAsync();
                    await RefreshAllAsync();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task RefreshAllAsync()
    {
        await RefreshAsync();
        await RefreshEventsAsync();
    }

    private async Task RefreshAsync()
    {
        try
        {
            _game = await ApiClient.GetGameAsync(GameId);
            EnsureHealingRayDefaults();
            PruneSelectedDice();
            PruneSelectedKeepAction();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void EnsureHealingRayDefaults()
    {
        var targets = HealingRayTargets.ToArray();
        if (targets.Length == 0 || AvailableHealingRayHearts <= 0)
        {
            _healingRayTargetPlayerId = -1;
            _healingRayAmount = 1;
            return;
        }

        if (!targets.Any(target => target.PlayerId == _healingRayTargetPlayerId))
        {
            _healingRayTargetPlayerId = targets[0].PlayerId;
        }

        var targetPlayer = targets.First(target => target.PlayerId == _healingRayTargetPlayerId);
        var maxHeal = Math.Min(AvailableHealingRayHearts, Math.Max(1, targetPlayer.MaxHealth - targetPlayer.Health));
        _healingRayAmount = Math.Clamp(_healingRayAmount, 1, maxHeal);
    }

    private void PruneSelectedDice()
    {
        if (_game?.CurrentTurn is null || !CanSelectDiceForReroll)
        {
            _selectedDiceIndexes.Clear();
            return;
        }

        var validIndexes = _game.CurrentTurn.Dice.Where(die => !die.IsLocked).Select(die => die.Index).ToHashSet();
        _selectedDiceIndexes.RemoveWhere(index => !validIndexes.Contains(index));
    }

    private void PruneSelectedKeepAction()
    {
        if (SelectedActionCard is null)
        {
            ClearSelectedKeepAction();
        }
    }

    private async Task RefreshEventsAsync()
    {
        try
        {
            var afterSequence = _eventFeed.Count == 0 ? 0 : Session.LastEventSequence;
            var cursor = await ApiClient.GetEventsAsync(GameId, afterSequence);
            if (cursor is null)
            {
                return;
            }

            foreach (var envelope in cursor.Events)
            {
                if (!_eventFeed.Any(item => item.Sequence == envelope.EventSequence))
                {
                    _eventFeed.Add(EventFeedItem.From(envelope, PlayerName));
                }
            }

            Session.LastEventSequence = cursor.CurrentEventSequence;
            await Session.SaveAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task ExecuteAsync(Func<Task<ApiCommandResultDto>> command)
    {
        _busy = true;
        _error = null;

        try
        {
            var result = await command();
            if (!result.Success)
            {
                _error = result.Error;
            }

            _game = result.GameState;
            EnsureHealingRayDefaults();
            _selectedDiceIndexes.Clear();
            PruneSelectedKeepAction();
            foreach (var newEvent in result.NewEvents)
            {
                _eventFeed.Add(EventFeedItem.From(Session.LastEventSequence + 1, newEvent, PlayerName));
                Session.LastEventSequence++;
            }

            if (result.CurrentEventSequence > Session.LastEventSequence)
            {
                Session.LastEventSequence = result.CurrentEventSequence;
            }

            await Session.SaveAsync();
            await RefreshEventsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private Task InitializeAsync() => ExecuteAsync(() => ApiClient.InitializeGameAsync(GameId));
    private Task BeginTurnAsync() => ExecuteAsync(() => ApiClient.BeginTurnAsync(GameId, new ActorRequest(Session.PlayerId)));
